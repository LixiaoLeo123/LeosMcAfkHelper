{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeosMcAfkHelper",
  "version": "0.1.0",
  "identifier": "com.leos.mcafkhelper",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Leo's Minecraft AFK Helper",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": ["resources/MinecraftClient-linux-x64"],
    "category": "Game"
  }
}
